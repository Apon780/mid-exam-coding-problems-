#include <stdio.h>

int main() {
    float num1, num2;
    char op;

    printf("Enter operator (+, -, *, /): ");
    scanf("%c", &op);

    printf("Enter two numbers: ");
    scanf("%f %f", &num1, &num2);

    switch(op) {
        case '+':
            printf("Result = %.2f", num1 + num2);
            break;

        case '-':
            printf("Result = %.2f", num1 - num2);
            break;

        case '*':
            printf("Result = %.2f", num1 * num2);
            break;

        case '/':
            if(num2 == 0)
                printf("Error! Division by zero is not allowed.");
            else
                printf("Result = %.2f", num1 / num2);
            break;

        default:
            printf("Invalid Operator");
    }

    return 0;
}